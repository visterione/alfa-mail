PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret_string

# Nextcloud WebDAV settings
NEXTCLOUD_URL=https://your-nextcloud.example.com
NEXTCLOUD_USER=nextcloud_user
NEXTCLOUD_PASSWORD=nextcloud_password
NEXTCLOUD_UPLOAD_PATH=/AlfaMail-Attachments
# Public share base URL (if different from NEXTCLOUD_URL)
NEXTCLOUD_SHARE_BASE=https://your-nextcloud.example.com

# File size threshold for Nextcloud upload (bytes), default 10MB
NEXTCLOUD_THRESHOLD=10485760
